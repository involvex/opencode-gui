{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "bun",
			"script": "debug:extension",
			"problemMatcher": [],
			"label": "bun: debug extension"
		},
		{
			"type": "bun",
			"script": "watch",
			"problemMatcher": {
				"owner": "typescript",
				"fileLocation": "relative",
				"pattern": {
					"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"code": 4,
					"message": 5
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\s*\\d{1,2}:\\d{1,2}:\\d{1,2}(?: AM| PM)? - File change detected\\. Starting incremental compilation\\.\\.\\.",
					"endsPattern": "^\\s*\\d{1,2}:\\d{1,2}:\\d{1,2}(?: AM| PM)? - (Compilation complete\\.|Found \\d+ errors?\\. Watching for file changes\\.)"
				}
			},
			"isBackground": true,
			"label": "bun: watch",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "bun",
			"script": "build:extension",
			"group": "build",
			"label": "build:extension",
			"problemMatcher": []
		}
	]
}
