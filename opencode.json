{
	"$schema": "https://opencode.ai/config.json",
	"share": "disabled",
	"server": {
		"port": 4096
	},
	"agent": {
		"main": {
			"description": "Primary coding agent"
		},
		"build": {
			"disable": true
		},
		"plan": {
			"disable": true
		}
	},
	"username": "",
	"provider": {
		"openai": {
			"models": {
				"gpt-5": {
					"options": {
						"reasoningEffort": "high",
						"textVerbosity": "low",
						"reasoningSummary": "auto",
						"include": ["reasoning.encrypted_content"]
					}
				}
			}
		},
		"anthropic": {
			"models": {
				"claude-opus-4-5-20251101": {
					"options": {
						"thinking": {
							"type": "enabled",
							"budgetTokens": 16000
						}
					}
				}
			}
		}
	},
	"permission": {
		"bash": {
			"*": "allow",
			"gcloud *": "ask",
			"*DB_TARGET=production*": "ask",
			"*NODE_ENV=production*": "ask"
		}
	},
	"mcp": {}
}
